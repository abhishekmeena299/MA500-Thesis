import networkx as nx
import matplotlib.pyplot as plt
import itertools
import random
from IPython.display import clear_output

def target_edges(n, target):
    nodes = list(range(n))
    k = int(target[1])
    subgraphs = []

    for combo in itertools.combinations(nodes, k):
        cycle_edges = [(combo[i], combo[(i+1)%k]) for i in range(k)]
        subgraphs.append(set(tuple(sorted(e)) for e in cycle_edges))

    return subgraphs


def check_maker_win(maker_edges, target_subgraphs):

    maker_set = set(tuple(sorted(e)) for e in maker_edges)

    for sub in target_subgraphs:
        if sub.issubset(maker_set):
            return True

    return False


# ======================
# Potential Functions
# ======================

def erdos_selfridge_potential(maker_edges, breaker_edges, target_subgraphs):

    maker_set = set(maker_edges)
    breaker_set = set(breaker_edges)

    total = 0
    max_val = 0

    for sub in target_subgraphs:

        k = len(sub)

        max_val += 2**(-k)

        if any(e in breaker_set for e in sub):
            continue

        maker_count = len(sub & maker_set)

        total += 2**(-(k - maker_count))

    return total / max_val if max_val > 0 else 0


def threat_based_potential(maker_edges, breaker_edges, target_subgraphs):

    maker_set = set(maker_edges)
    breaker_set = set(breaker_edges)

    threats = 0

    for sub in target_subgraphs:

        if any(e in breaker_set for e in sub):
            continue

        maker_count = len(sub & maker_set)

        if maker_count == len(sub) - 1:
            threats += 1

    return threats / len(target_subgraphs)


def degree_based_potential(maker_edges, breaker_edges, target_subgraphs, n):

    maker_set = set(maker_edges)

    deg = [0]*n

    for u,v in maker_set:
        deg[u]+=1
        deg[v]+=1

    max_deg = max(deg) if deg else 1

    return max_deg/(n-1)


def edge_participation_potential(maker_edges, breaker_edges, target_subgraphs):

    maker_set = set(maker_edges)

    total = 0

    for e in maker_set:

        count = 0

        for sub in target_subgraphs:
            if e in sub:
                count +=1

        total += count

    max_possible = len(target_subgraphs)*len(next(iter(target_subgraphs)))

    return total/max_possible if max_possible>0 else 0


# ======================
# Hybrid Potential
# ======================

def hybrid_potential(maker_edges, breaker_edges, target_subgraphs, weights, n):

    p1 = erdos_selfridge_potential(maker_edges, breaker_edges, target_subgraphs)
    p2 = threat_based_potential(maker_edges, breaker_edges, target_subgraphs)
    p3 = degree_based_potential(maker_edges, breaker_edges, target_subgraphs, n)
    p4 = edge_participation_potential(maker_edges, breaker_edges, target_subgraphs)

    w1,w2,w3,w4 = weights

    total_weight = w1+w2+w3+w4

    return (w1*p1 + w2*p2 + w3*p3 + w4*p4)/total_weight


# ======================
# Wrapper
# ======================

def compute_potential(potential_type,
                      maker_edges,
                      breaker_edges,
                      target_subgraphs,
                      weights,
                      n):

    if potential_type == 1:
        return erdos_selfridge_potential(maker_edges, breaker_edges, target_subgraphs)

    if potential_type == 2:
        return threat_based_potential(maker_edges, breaker_edges, target_subgraphs)

    if potential_type == 3:
        return degree_based_potential(maker_edges, breaker_edges, target_subgraphs, n)

    if potential_type == 4:
        return edge_participation_potential(maker_edges, breaker_edges, target_subgraphs)

    if potential_type == 5:
        return hybrid_potential(maker_edges, breaker_edges, target_subgraphs, weights, n)


# ======================
# Graph drawing
# ======================

def draw_graph(G, maker_edges, breaker_edges, pos):

    plt.clf()

    nx.draw_networkx_nodes(G, pos,
                           node_color="lightgrey",
                           node_size=500)

    remaining_edges = [
        e for e in G.edges()
        if e not in maker_edges and e not in breaker_edges
    ]

    nx.draw_networkx_edges(G, pos,
                           edgelist=remaining_edges,
                           edge_color="grey",
                           style="dotted",
                           width=1.5)

    nx.draw_networkx_edges(G, pos,
                           edgelist=maker_edges,
                           edge_color="red",
                           width=2)

    nx.draw_networkx_edges(G, pos,
                           edgelist=breaker_edges,
                           edge_color="blue",
                           width=2)

    nx.draw_networkx_labels(G, pos)

    plt.axis("off")
    plt.title("Maker (Red) vs Breaker (Blue)")
    plt.show(block=False)
    plt.pause(0.1)


# ======================
# Game Setup
# ======================

n = int(input("Enter n for K_n: "))
q = int(input("Enter Breaker bias q: "))
target_choice = input("Target graph (C3,C4,C5): ").upper()

print("\nChoose potential function:")
print("1 - Erdős–Selfridge")
print("2 - Threat-based")
print("3 - Degree-based")
print("4 - Edge Participation")
print("5 - Hybrid")

potential_type = int(input("Enter choice: "))

weights = None

if potential_type == 5:

    print("\nEnter weights for hybrid potential")

    w1 = float(input("Weight for Erdős–Selfridge: "))
    w2 = float(input("Weight for Threat: "))
    w3 = float(input("Weight for Degree: "))
    w4 = float(input("Weight for Edge Participation: "))

    weights = (w1,w2,w3,w4)


G = nx.complete_graph(n)

pos = nx.spring_layout(G, seed=42)

target_subgraphs = target_edges(n, target_choice)

maker_edges = []
breaker_edges = []

available_edges = list(G.edges())
random.shuffle(available_edges)

clear_output(wait=True)

print(f"Game started on K{n}, target {target_choice}")

draw_graph(G, maker_edges, breaker_edges, pos)

pot = compute_potential(potential_type,
                        maker_edges,
                        breaker_edges,
                        target_subgraphs,
                        weights,
                        n)

print("Initial Potential:", round(pot,4))


# ======================
# Gameplay Loop
# ======================

turn = 1

while available_edges:

    print(f"\n--- Turn {turn} ---")

    maker_move = input("Maker move (u v): ")

    try:

        u,v = map(int,maker_move.split())

        edge = tuple(sorted((u,v)))

        if edge not in available_edges:
            print("Invalid edge")
            continue

    except:
        print("Invalid input")
        continue

    maker_edges.append(edge)
    available_edges.remove(edge)

    draw_graph(G, maker_edges, breaker_edges, pos)

    pot = compute_potential(potential_type,
                            maker_edges,
                            breaker_edges,
                            target_subgraphs,
                            weights,
                            n)

    print("Potential after Maker move:",round(pot,4))

    if check_maker_win(maker_edges,target_subgraphs):
        print("🎉 Maker wins")
        break


    for i in range(q):

        if not available_edges:
            break

        breaker_move = input(f"Breaker move {i+1}/{q}: ")

        try:

            u,v = map(int,breaker_move.split())

            edge = tuple(sorted((u,v)))

            if edge not in available_edges:
                print("Invalid edge")
                continue

        except:
            print("Invalid input")
            continue

        breaker_edges.append(edge)
        available_edges.remove(edge)

        draw_graph(G, maker_edges, breaker_edges, pos)

        pot = compute_potential(potential_type,
                                maker_edges,
                                breaker_edges,
                                target_subgraphs,
                                weights,
                                n)

        print("Potential after Breaker move:",round(pot,4))

    turn +=1


print("\nFinal Board")

draw_graph(G, maker_edges, breaker_edges, pos)
